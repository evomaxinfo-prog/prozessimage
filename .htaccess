# ProModXgOEM Frontend – Sicherheits-Header
# Falls IONOS/Plesk rein auf nginx läuft und .htaccess ignoriert, dieselben Header
# unter "Apache & nginx Einstellungen" -> "Zusätzliche nginx-Direktiven" setzen.

<IfModule mod_headers.c>
  # Content-Security-Policy: ausschliesslich eigene Quellen + API-Origin. Keine Drittanbieter (Schriften selbst gehostet).
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://api.prozessimage.de; connect-src 'self' https://api.prozessimage.de; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=(), browsing-topics=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  # HSTS mit includeSubDomains + preload (nur wenn ALLE Subdomains dauerhaft per HTTPS laufen)
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  # Server-/Framework-Kennung nicht preisgeben
  Header unset X-Powered-By
  Header always unset X-Powered-By
</IfModule>
# Serverkennung reduzieren (falls erlaubt)
ServerSignature Off

# Punktdateien (.git, .env, .htaccess …) nicht ausliefern
<FilesMatch "(^\.|composer\.(json|lock)|\.md$)">
  Require all denied
</FilesMatch>

# --- Ladezeit: Komprimierung (ca. 70 % weniger Übertragung bei JS/CSS) ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Ladezeit: Browser-Caching. Die ?v=-Version in den URLs invalidiert bei Updates sauber. ---
<IfModule mod_headers.c>
  # HTML immer frisch prüfen (holt neue ?v=-Verweise)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Statische Assets lange cachen (durch ?v= bei Änderung sofort neu geladen)
  <FilesMatch "\.(css|js|png|jpe?g|gif|webp|svg|woff2?|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
